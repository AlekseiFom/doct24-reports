    {
      "name": "Авторизация",
      "item": [
        {
          "name": "Получение свежего токена",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "   pm.response.to.have.status(200);\r",
                  "if (pm.response.code === 200) {\r",
                  "        \r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "        if (jsonData.access) {\r",
                  "        pm.collectionVariables.set(\"access\", jsonData.access);\r",
                  "        console.log(\"✅ Access токен сохранен\");\r",
                  "    }\r",
                  "\r",
                  "    \r",
                  "    if (jsonData.refresh) {\r",
                  "        pm.collectionVariables.set(\"refresh\", jsonData.refresh);\r",
                  "        console.log(\"✅ Refresh токен сохранен\");\r",
                  "    }\r",
                  "    pm.test(\"Status code is 200\", function () {\r",
                  "     \r",
                  "    });\r",
                  "    \r",
                  "} else {\r",
                  "    console.log(\"❌ Ошибка при получении токенов: \" + pm.response.status);\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "accept",
                "value": "*/*"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-CSRFTOKEN",
                "value": "sVpOhd1g4yJlshkZevFCMnR4GbDJqR4l9aOouNjnNuLjKwF3mamo7aA5Rswti6kg"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"f@uk59.ru\",\n  \"password\": \"1234test\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/jwt/create/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "jwt",
                "create",
                ""
              ]
            },
            "description": "Generated from cURL: curl -X 'POST'  \n'[https://api.test.telemed.doct24.com/api/users/create/'](https://api.test.telemed.doct24.com/api/users/create/')  \n\\-H 'accept: _/_'  \n\\-H 'Content-Type: application/json'  \n\\-H 'X-CSRFTOKEN: sVpOhd1g4yJlshkZevFCMnR4GbDJqR4l9aOouNjnNuLjKwF3mamo7aA5Rswti6kg'  \n\\-d '{  \n\"username\": \"Алёша\",  \n\"email\": \"[f@uk59.ru](https://mailto:f@uk59.ru)\",  \n\"role\": \"patient\",  \n\"password\": \"string\"  \n}'"
          },
