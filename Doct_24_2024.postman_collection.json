              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "// Разбор тела\r",
                  "let json = pm.response.json();\r",
                  "\r",
                  "// Проверка основных полей ответа\r",
                  "pm.test(\"Есть id отзыва\", function () {\r",
                  "    pm.expect(json.id).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"rating совпадает по значению и ≤ 5\", function () {\r",
                  "    const reqBody = JSON.parse(pm.request.body.raw);\r",
                  "    const sent = Number(reqBody.rating);               // 5 или \"5\" -> 5\r",
                  "    const got = Number(pm.response.json().rating);     // \"5.0\" -> 5\r",
                  "\r",
                  "    pm.expect(got).to.eql(sent);\r",
                  "    pm.expect(got).to.be.at.most(5);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"text совпадает с отправленным и ≤ 1000 символов\", function () {\r",
                  "    const sent = JSON.parse(pm.request.body.raw).text;\r",
                  "    pm.expect(json.text).to.eql(sent);\r",
                  "    pm.expect(json.text.length).to.be.below(1001);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Поле created присутствует\", function () {\r",
                  "    pm.expect(json.created).to.exist;\r",
                  "});"
                ],
